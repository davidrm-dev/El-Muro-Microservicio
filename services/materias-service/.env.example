# ============================================================
# ARCHIVO DE EJEMPLO - COPIAR A .env Y LLENAR CON TUS VALORES
# Este archivo muestra la estructura de variables necesarias
# NO SUBIR .env a GitHub - usar solo .env.example
# ============================================================

# Nombre del servicio
SERVICE_NAME=materias-service
SERVICE_PORT=8002
ENVIRONMENT=development

# Base de datos PostgreSQL
DATABASE_URL=postgresql://<usuario>:<password>@<host>:<puerto>/<database>
POSTGRES_USER=<tu-usuario>
POSTGRES_PASSWORD=<tu-password>
POSTGRES_DB=<nombre-base-datos>
POSTGRES_HOST=<host-postgres>
POSTGRES_PORT=5433

# JWT - IMPORTANTE: Debe ser la MISMA en todos los microservicios
JWT_SECRET=<tu-secret-key-muy-segura>

# Otros microservicios
CARRERAS_SERVICE_URL=http://<host>:<puerto>
USUARIOS_SERVICE_URL=http://<host>:<puerto>

# Logging
LOG_LEVEL=INFO

# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env en el mismo directorio
# 2. Reemplaza los valores ficticios con los valores reales
# 3. Nunca commits .env a Git
# 4. Comparte .env de forma segura (1password, Doppler, etc)
# ============================================================
