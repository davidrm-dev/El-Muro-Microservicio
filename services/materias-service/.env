# Database
DATABASE_URL=postgresql://usuario:password@materias-db:5432/materias_db
POSTGRES_USER=usuario
POSTGRES_PASSWORD=password
POSTGRES_DB=materias_db
POSTGRES_HOST=materias-db
POSTGRES_PORT=5432

# Service
SERVICE_NAME=materias-service
SERVICE_PORT=8002
ENVIRONMENT=development

# Eureka
EUREKA_SERVER=http://eureka-server:8761/eureka/

# JWT (Debe ser la misma en todos los servicios)
JWT_SECRET=tu-secret-key-super-segura-para-desarrollo-12345

# Other Services (para integraciones futuras)
CARRERAS_SERVICE_URL=http://carreras-service:8001
USUARIOS_SERVICE_URL=http://usuarios-service:8003
