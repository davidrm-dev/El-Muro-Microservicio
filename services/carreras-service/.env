# Database
DATABASE_URL=postgresql://usuario:password@127.0.0.1:5434/carreras_db
POSTGRES_USER=usuario
POSTGRES_PASSWORD=password
POSTGRES_DB=carreras_db
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5434

# Service
SERVICE_NAME=carreras-service
SERVICE_PORT=8001
ENVIRONMENT=development

# Eureka
EUREKA_SERVER=http://127.0.0.1:8761/eureka/

# JWT (Debe ser la misma en todos los servicios)
JWT_SECRET=tu-secret-key-super-segura-para-desarrollo-12345

# Other Services (para integraciones futuras)
MATERIAS_SERVICE_URL=http://materias-service:8002
USUARIOS_SERVICE_URL=http://usuarios-service:8003
