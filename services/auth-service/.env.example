# Service
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/el-muro-auth

# Auth
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN_HOURS=6

# SheerID
SHEERID_BASE_URL=https://services-sandbox.sheerid.com/rest/v2
SHEERID_API_TOKEN=your-sheerid-token

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_FROM=no-reply@uptc.edu.co

# Internal services security
INTERNAL_SERVICE_SECRET=internal-secret
TRUSTED_SERVICE_IDS=materias-service,posts-service,temas-service

# Login security
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# Eureka service discovery
EUREKA_ENABLED=true
EUREKA_HOST=localhost
EUREKA_PORT=8761
EUREKA_SERVICE_NAME=auth-service
EUREKA_INSTANCE_HOST=localhost
