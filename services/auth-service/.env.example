# ============================================================
# ARCHIVO DE EJEMPLO - COPIAR A .env Y LLENAR CON TUS VALORES
# Este archivo muestra la estructura de variables necesarias
# NO SUBIR .env a GitHub - usar solo .env.example
# ============================================================

# Puerto del servicio
PORT=3000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://<usuario>:<password>@<host>:<puerto>/<database>?authSource=admin

# JWT - IMPORTANTE: Debe ser la MISMA en todos los microservicios
JWT_SECRET=<tu-secret-key-muy-segura>
JWT_EXPIRES_IN_HOURS=24

# Servicios externos (SheerID - Verificación académica)
SHEERID_BASE_URL=https://services-sandbox.sheerid.com/rest/v2
SHEERID_API_TOKEN=<tu-token-sheerid>

# SMTP (Email)
SMTP_HOST=<tu-host-smtp>
SMTP_PORT=<tu-puerto-smtp>
SMTP_SECURE=false
SMTP_USER=<tu-usuario-smtp>
SMTP_PASS=<tu-password-smtp>
SMTP_FROM=noreply@uptc.edu.co

# Validación entre microservicios
INTERNAL_SERVICE_SECRET=<tu-secret-interno>
TRUSTED_SERVICE_IDS=carreras-service,materias-service

# Seguridad: Límite de intentos de login
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env en el mismo directorio
# 2. Reemplaza los valores ficticios con los valores reales
# 3. Nunca commits .env a Git
# 4. Comparte .env de forma segura (1password, Doppler, etc)
# ============================================================
